LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
