# Gmail SMTP（新使用者待審核通知信；GMAIL_APP_PASSWORD 是 Google 帳戶「應用程式密碼」，
# 不是登入密碼，需要先開啟兩步驟驗證才能產生）
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=
